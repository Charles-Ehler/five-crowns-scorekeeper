rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Five Crowns Scorekeeper: no auth, casual family game tool.
    // Scoped to this app's two dedicated collections only.
    match /fiveCrowns_games/{gameId} {
      allow read, write: if true;
    }

    match /fiveCrowns_players/{playerId} {
      allow read, write: if true;
    }
  }
}
